@prefix : <http://owkin.com/discordance/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://owkin.com/discordance/ontology#> a owl:Ontology ;
    rdfs:label "Discordance OR-in-Cancer Evidence Ontology" ;
    rdfs:comment "Contradiction-aware evidence graph for olfactory receptors in cancer." .


# ── Classes ──
:Receptor a owl:Class ; rdfs:label "Receptor" .
:CancerType a owl:Class ; rdfs:label "CancerType" .
:ModelSystem a owl:Class ; rdfs:label "ModelSystem" .
:Endpoint a owl:Class ; rdfs:label "Endpoint" .
:Paper a owl:Class ; rdfs:label "Paper" .
:Claim a owl:Class ; rdfs:label "Claim" .
:Direction a owl:Class ; rdfs:label "Direction" .
:Ligand a owl:Class ; rdfs:label "Ligand" .
:Mechanism a owl:Class ; rdfs:label "Mechanism" .
:ClassA_OR a owl:Class ; rdfs:subClassOf :Receptor ; rdfs:label "ClassA_OR" .
:EctopicallyExpressedOR a owl:Class ; rdfs:subClassOf :Receptor ; rdfs:label "EctopicallyExpressedOR" .
:OdorantLigand a owl:Class ; rdfs:subClassOf :Ligand ; rdfs:label "OdorantLigand" .
:MetaboliteLigand a owl:Class ; rdfs:subClassOf :Ligand ; rdfs:label "MetaboliteLigand" .
:BiasedAgonist a owl:Class ; rdfs:subClassOf :Ligand ; rdfs:label "BiasedAgonist" .
:EndogenousReceptorModel a owl:Class ; rdfs:subClassOf :ModelSystem ; rdfs:label "EndogenousReceptorModel" .
:HeterologousExpressionModel a owl:Class ; rdfs:subClassOf :ModelSystem ; rdfs:label "HeterologousExpressionModel" .
:XenograftModel a owl:Class ; rdfs:subClassOf :ModelSystem ; rdfs:label "XenograftModel" .
:CohortStudy a owl:Class ; rdfs:subClassOf :ModelSystem ; rdfs:label "CohortStudy" .
:ProliferationEndpoint a owl:Class ; rdfs:subClassOf :Endpoint ; rdfs:label "ProliferationEndpoint" .
:InvasivenessEndpoint a owl:Class ; rdfs:subClassOf :Endpoint ; rdfs:label "InvasivenessEndpoint" .
:ApoptosisEndpoint a owl:Class ; rdfs:subClassOf :Endpoint ; rdfs:label "ApoptosisEndpoint" .
:ExpressionEndpoint a owl:Class ; rdfs:subClassOf :Endpoint ; rdfs:label "ExpressionEndpoint" .
:PrognosisEndpoint a owl:Class ; rdfs:subClassOf :Endpoint ; rdfs:label "PrognosisEndpoint" .
:ActivationEffectClaim a owl:Class ; rdfs:subClassOf :Claim ; rdfs:label "ActivationEffectClaim" .
:ExpressionPatternClaim a owl:Class ; rdfs:subClassOf :Claim ; rdfs:label "ExpressionPatternClaim" .
:GeneticAlterationClaim a owl:Class ; rdfs:subClassOf :Claim ; rdfs:label "GeneticAlterationClaim" .
:CommercialInterestClaim a owl:Class ; rdfs:subClassOf :Claim ; rdfs:label "CommercialInterestClaim" .
:PrimaryStudyPaper a owl:Class ; rdfs:subClassOf :Paper ; rdfs:label "PrimaryStudyPaper" .
:ReviewPaper a owl:Class ; rdfs:subClassOf :Paper ; rdfs:label "ReviewPaper" .
:PatentDocument a owl:Class ; rdfs:subClassOf :Paper ; rdfs:label "PatentDocument" .
:DatabaseDerivedRecord a owl:Class ; rdfs:subClassOf :Paper ; rdfs:label "DatabaseDerivedRecord" .
:PreliminaryStudyPaper a owl:Class ; rdfs:subClassOf :Paper ; rdfs:label "PreliminaryStudyPaper" .

# ── Properties ──
:about_receptor a owl:ObjectProperty ; rdfs:label "about_receptor" ; rdfs:domain :Claim ; rdfs:range [ owl:unionOf (:Receptor, :ClassA_OR) ] .
:in_cancer a owl:ObjectProperty ; rdfs:label "in_cancer" ; rdfs:domain :Claim ; rdfs:range [ owl:unionOf (:CancerType) ] .
:in_model a owl:ObjectProperty ; rdfs:label "in_model" ; rdfs:domain :Claim ; rdfs:range [ owl:unionOf (:ModelSystem) ] .
:measures_endpoint a owl:ObjectProperty ; rdfs:label "measures_endpoint" ; rdfs:domain :Claim ; rdfs:range [ owl:unionOf (:Endpoint) ] .
:asserts_direction a owl:ObjectProperty ; rdfs:label "asserts_direction" ; rdfs:domain :Claim ; rdfs:range [ owl:unionOf (:Direction) ] .
:from_paper a owl:ObjectProperty ; rdfs:label "from_paper" ; rdfs:domain :Claim ; rdfs:range [ owl:unionOf (:Paper) ] .
:via_mechanism a owl:ObjectProperty ; rdfs:label "via_mechanism" ; rdfs:domain :Claim ; rdfs:range [ owl:unionOf (:Mechanism) ] .
:uses_ligand a owl:ObjectProperty ; rdfs:label "uses_ligand" ; rdfs:domain :Claim ; rdfs:range [ owl:unionOf (:Ligand, :OdorantLigand, :BiasedAgonist) ] .
:tension_with a owl:ObjectProperty ; rdfs:label "tension_with" ; rdfs:domain :Claim ; rdfs:range [ owl:unionOf (:Claim) ] .
:hasDirection a owl:DatatypeProperty ; rdfs:label "tumor_suppressive | tumor_promoting | neutral" .
:hasWeight a owl:DatatypeProperty ; rdfs:label "evidence weight score" .
:hasDirectionContext a owl:DatatypeProperty ; rdfs:label "activation_effect | expression_pattern | genetic_alteration" .
:hasSourceType a owl:DatatypeProperty ; rdfs:label "primary_study | review | patent | …" .

# ── Evidence individuals (sample) ──
